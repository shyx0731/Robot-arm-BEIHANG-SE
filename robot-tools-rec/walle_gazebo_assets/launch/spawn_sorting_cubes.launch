<!--
  在 Gazebo 已启动后生成仿真分拣桌上的彩色箱子。
  walle_core 原版 launch 引用 wpr_simulation/models/cubes/（官方包不存在），
  需用本 launch 补生成。

  单独使用（Gazebo 已在跑）：
    roslaunch walle_gazebo_assets spawn_sorting_cubes.launch

  一键仿真（推荐）：
    roslaunch walle_gazebo_assets walle_circumstances_with_boxes.launch
-->
<launch>
  <arg name="cube_z" default="0.79"/>

  <node name="red_box_1_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_1_1 -x 1.4 -y 1.1 -z $(arg cube_z)"/>
  <node name="red_box_1_2" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_1_2 -x 1.4 -y 1.3 -z $(arg cube_z)"/>
  <node name="red_box_2_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_2_1 -x 1.4 -y 1.5 -z $(arg cube_z)"/>
  <node name="red_box_3_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_3_1 -x 1.4 -y 1.7 -z $(arg cube_z)"/>
  <node name="green_box_1_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/green_cube.sdf -model green_box_1_1 -x 1.4 -y 1.9 -z $(arg cube_z)"/>
  <node name="green_box_1_2" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/green_cube.sdf -model green_box_1_2 -x 1.6 -y 1.1 -z $(arg cube_z)"/>
  <node name="green_box_2_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/green_cube.sdf -model green_box_2_1 -x 1.6 -y 1.3 -z $(arg cube_z)"/>
  <node name="yellow_box_1_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/yellow_cube.sdf -model yellow_box_1_1 -x 1.6 -y 1.5 -z $(arg cube_z)"/>
  <node name="yellow_box_1_2" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/yellow_cube.sdf -model yellow_box_1_2 -x 1.6 -y 1.7 -z $(arg cube_z)"/>
  <node name="yellow_box_2_1" pkg="gazebo_ros" type="spawn_model"
        args="-wait -sdf -file $(find walle_gazebo_assets)/models/cubes/yellow_cube.sdf -model yellow_box_2_1 -x 1.6 -y 1.9 -z $(arg cube_z)"/>
</launch>
