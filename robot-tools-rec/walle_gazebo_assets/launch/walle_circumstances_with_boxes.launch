<!--
  仿真分拣 + 桌上彩色箱子（推荐入口）
  这里关闭 walle_core 自带的场景箱子生成，避免重复 spawn。

  终端 1：
    roslaunch walle_gazebo_assets walle_circumstances_with_boxes.launch

  终端 2（Web 控制台，可选）：
    roslaunch walle_web_console web_ui.launch

  终端 2（RQT 控制台，可选）：
    roslaunch rqt_task_dashboard walle_dashboard.launch
-->
<launch>
  <include file="$(find walle_core)/launch/walle_sorting.launch">
    <arg name="sim" value="true"/>
    <arg name="map_file" value="$(find walle_core)/maps/wpb_gmapping_map.yaml"/>
    <arg name="config_file" value="$(find walle_core)/config/sim_sorting.yaml"/>
    <arg name="fsm_startup_delay" value="8"/>
    <arg name="spawn_sorting_scene" value="false"/>
  </include>
  <include file="$(find walle_gazebo_assets)/launch/spawn_sorting_cubes.launch"/>
</launch>
