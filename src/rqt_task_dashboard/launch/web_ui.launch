<!--
  Web 浏览器控制台（需先启动分拣系统）

  一键启动（推荐，不要另开 rosbridge）：
    roslaunch rqt_task_dashboard web_ui.launch

  若已单独启动过 rosbridge / rosapi，避免重复节点：
    roslaunch rqt_task_dashboard web_ui.launch start_rosbridge:=false start_rosapi:=false

  浏览器 http://localhost:8080 → 点击「连接 ROS」
-->
<launch>
  <arg name="port" default="8080"/>
  <arg name="rosbridge_port" default="9090"/>
  <arg name="enable_vision_stream" default="true"/>
  <arg name="start_rosbridge" default="true"/>
  <arg name="start_rosapi" default="true"/>
  <arg name="vision_in_topic" default="/vision/debug_image"/>
  <arg name="vision_out_topic" default="/vision/debug_image/compressed"/>

  <group if="$(arg start_rosbridge)">
    <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch">
      <arg name="port" value="$(arg rosbridge_port)"/>
    </include>
  </group>

  <group if="$(arg start_rosapi)">
    <node pkg="rosapi" type="rosapi_node" name="walle_rosapi" output="screen"/>
  </group>

  <node pkg="rqt_task_dashboard" type="web_server.py" name="walle_web_server" output="screen">
    <param name="port" value="$(arg port)"/>
  </node>

  <group if="$(arg enable_vision_stream)">
    <node pkg="rqt_task_dashboard" type="vision_compress_node.py" name="walle_vision_compress" output="screen">
      <param name="in_topic" value="$(arg vision_in_topic)"/>
      <param name="out_topic" value="$(arg vision_out_topic)"/>
      <param name="jpeg_quality" value="80"/>
    </node>
  </group>
</launch>
