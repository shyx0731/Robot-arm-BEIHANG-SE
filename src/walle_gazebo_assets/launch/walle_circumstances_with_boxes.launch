<!--
  仿真分拣场景（仅 Gazebo + 桌子 + 彩色箱子）

  这个入口只负责把场景拉起来，不启动 walle_core 的控制器/业务节点，
  避免卡在 controller_spawner / 视觉节点上。

  运行：
    roslaunch walle_gazebo_assets walle_circumstances_with_boxes.launch
-->
<launch>
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find wpr_simulation)/worlds/robocup_home.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="recording" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <node name="spawn_simple_table" pkg="gazebo_ros" type="spawn_model"
        args="-file $(find wpr_simulation)/models/table.model -urdf -model sorting_table -x 1.5 -y 1.5 -z 0 -Y 0"/>

  <include file="$(find walle_gazebo_assets)/launch/spawn_sorting_cubes.launch"/>
</launch>
