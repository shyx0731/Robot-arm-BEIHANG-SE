<!--
  Gazebo 仿真环境
  spawn_sorting_scene:=true  → robocup_home 世界 + 桌子 + 箱子（walle_circumstances 用）
  spawn_sorting_scene:=false → 空地面 + 仅机器人（walle_real_in_sim 用）
-->
<launch>
  <arg name="enable_gui" default="true"/>
  <arg name="spawn_sorting_scene" default="true"/>
  <arg name="world_name" default="$(find wpr_simulation)/worlds/robocup_home.world"/>

  <group if="$(arg spawn_sorting_scene)">
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
      <arg name="world_name" value="$(arg world_name)"/>
      <arg name="paused" value="false"/>
      <arg name="use_sim_time" value="true"/>
      <arg name="gui" value="$(arg enable_gui)"/>
      <arg name="recording" value="false"/>
      <arg name="debug" value="false"/>
    </include>
  </group>
  <group unless="$(arg spawn_sorting_scene)">
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
      <arg name="paused" value="false"/>
      <arg name="use_sim_time" value="true"/>
      <arg name="gui" value="$(arg enable_gui)"/>
      <arg name="recording" value="false"/>
      <arg name="debug" value="false"/>
    </include>
  </group>

  <group if="$(arg spawn_sorting_scene)">
    <node name="spawn_simple_table" pkg="gazebo_ros" type="spawn_model"
          args="-file $(find wpr_simulation)/models/table.model -urdf -model sorting_table -x 1.5 -y 1.5 -z 0 -Y 0"/>

    <!-- 箱子必须在桌子之后生成，否则会因竞态条件掉到地面 -->
    <!-- 桌面顶部 z = 0.765 + 0.015 = 0.78，箱子底部需在 0.78 以上 -->
    <!-- walle_gazebo_assets SDF 无 link pose 偏移，z=0.83 → 底部 0.78，刚好在桌面上 -->
    <node name="red_box_1_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_1_1 -x 1.4 -y 1.1 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="red_box_1_2" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_1_2 -x 1.4 -y 1.3 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="red_box_2_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_2_1 -x 1.4 -y 1.5 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="red_box_3_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/red_cube.sdf -model red_box_3_1 -x 1.4 -y 1.7 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="green_box_1_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/green_cube.sdf -model green_box_1_1 -x 1.4 -y 1.9 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="green_box_1_2" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/green_cube.sdf -model green_box_1_2 -x 1.6 -y 1.1 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="green_box_2_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/green_cube.sdf -model green_box_2_1 -x 1.6 -y 1.3 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="yellow_box_1_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/yellow_cube.sdf -model yellow_box_1_1 -x 1.6 -y 1.5 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="yellow_box_1_2" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/yellow_cube.sdf -model yellow_box_1_2 -x 1.6 -y 1.7 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
    <node name="yellow_box_2_1" pkg="gazebo_ros" type="spawn_model"
          args="-sdf -file $(find walle_gazebo_assets)/models/cubes/yellow_cube.sdf -model yellow_box_2_1 -x 1.6 -y 1.9 -z 0.83" launch-prefix="bash -c 'sleep 3; $0 $@' "/>
  </group>

  <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
        args="-file $(find wpr_simulation)/models/wpb_home_mani.model -urdf -model wpb_home -x 0.0 -y 0.0 -z 0"/>

  <include file="$(find wpr_simulation)/launch/wpb_home_controllers.launch"/>
</launch>
